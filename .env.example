# ─── App ──────────────────────────────────────────────────────────────────────
# Public vars are exposed to the browser (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_APP_NAME=NewEffect MTD ITSA
NEXT_PUBLIC_APP_ENV=development

# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for backend API (leave empty to use mock data)
NEXT_PUBLIC_API_BASE_URL=

# ─── Server-only vars (no NEXT_PUBLIC_ prefix — never exposed to browser) ─────
# Add server-side secrets here, e.g. database URLs, API keys
# DATABASE_URL=
# SECRET_KEY=
